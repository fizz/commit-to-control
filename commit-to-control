#!/usr/bin/env python3
"""Map a git commit to NIST 800-171 controls via vector similarity + LLM judge.

Embeds your commit diff, searches a pgvector table of NIST controls,
then uses an LLM judge to filter false positives from the vector search.

Supports AWS Bedrock and OpenAI-compatible providers (OpenAI, Ollama, vLLM,
LM Studio, llama.cpp — anything that speaks the OpenAI API).

Usage:
    commit-to-control [commit-sha]    # defaults to HEAD
    commit-to-control --seed          # one-time: embed controls into pgvector
    commit-to-control --status        # check if controls are seeded

Environment:
    COMMIT2CONTROL_DB       PostgreSQL connection string (must have pgvector extension)
    COMMIT2CONTROL_PROVIDER "bedrock" or "openai" (default: openai)

    For bedrock:
        AWS_REGION              AWS region
        EMBED_MODEL             Bedrock embedding model (default: amazon.titan-embed-text-v2:0)
        JUDGE_MODEL             Bedrock judge model (default: anthropic.claude-3-haiku-20240307-v1:0)

    For openai (also covers Ollama, vLLM, etc.):
        OPENAI_API_KEY          API key (use "ollama" for Ollama)
        OPENAI_BASE_URL         Base URL (default: https://api.openai.com/v1, use http://localhost:11434/v1 for Ollama)
        EMBED_MODEL             Embedding model (default: text-embedding-3-small)
        JUDGE_MODEL             Chat model for judging (default: gpt-4o-mini)

Requires:
    pip: psycopg2-binary, boto3 (for bedrock), openai (for openai provider)
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

import psycopg2

# --- Config ---
DB_CONN = os.environ["COMMIT2CONTROL_DB"]
PROVIDER = os.environ.get("COMMIT2CONTROL_PROVIDER", "openai")
EMBED_DIMS = 1024
TOP_K = 8

# Load controls from JSON (generated by Makefile from NIST XLSX)
CONTROLS_PATH = Path(__file__).resolve().parent / "controls.json"
if not CONTROLS_PATH.exists():
    print(f"controls.json not found at {CONTROLS_PATH}. Run: make controls", file=sys.stderr)
    sys.exit(1)
CONTROLS = json.loads(CONTROLS_PATH.read_text())


# ---------------------------------------------------------------------------
# Cost tracking
# ---------------------------------------------------------------------------

# Per-token prices (USD). Loaded from pricing.json (generated by `make pricing`).
# For self-hosted (Ollama etc.), models won't appear in the file and cost shows as $0.
PRICING_PATH = Path(__file__).resolve().parent / "pricing.json"
if PRICING_PATH.exists():
    MODEL_PRICES = json.loads(PRICING_PATH.read_text())
else:
    MODEL_PRICES = {}


class CostTracker:
    def __init__(self):
        self.items = []

    def record(self, step, model, input_tokens=0, output_tokens=0):
        prices = MODEL_PRICES.get(model, {})
        cost = (input_tokens * prices.get("input", 0)) + (output_tokens * prices.get("output", 0))
        self.items.append({
            "step": step, "model": model,
            "input_tokens": input_tokens, "output_tokens": output_tokens,
            "cost": cost,
        })

    def print_summary(self):
        if not self.items:
            return
        total = sum(i["cost"] for i in self.items)
        print("Cost Estimate:")
        print("-" * 72)
        print(f"  {'Step':<25} {'Model':<35} {'Tokens':>8} {'Cost':>10}")
        print(f"  {'-'*25} {'-'*35} {'-'*8} {'-'*10}")
        for i in self.items:
            tokens = i["input_tokens"] + i["output_tokens"]
            print(f"  {i['step']:<25} {i['model']:<35} {tokens:>8} ${i['cost']:>9.6f}")
        print(f"  {'-'*25} {'-'*35} {'-'*8} {'-'*10}")
        print(f"  {'Total':<25} {'':<35} {'':>8} ${total:>9.6f}")
        if total > 0:
            monthly = total * 50  # rough: 10 PRs/day, 5 days/week
            print(f"  {'~monthly (10 PRs/day)':<25} {'':<35} {'':>8} ${monthly:>9.4f}")
        print()


costs = CostTracker()


# ---------------------------------------------------------------------------
# Provider abstraction — two code paths, no framework
# ---------------------------------------------------------------------------

def _get_bedrock_client():
    import boto3
    return boto3.Session(region_name=os.environ["AWS_REGION"]).client("bedrock-runtime")


def _embed_bedrock(client, text: str, model: str) -> list[float]:
    body = json.dumps({"inputText": text[:8000], "dimensions": EMBED_DIMS})
    response = client.invoke_model(
        modelId=model, contentType="application/json",
        accept="application/json", body=body,
    )
    result = json.loads(response["body"].read())
    input_tokens = result.get("inputTextTokenCount", len(text) // 4)
    costs.record("embed", model, input_tokens=input_tokens)
    return result["embedding"]


def _judge_bedrock(client, prompt: str, model: str) -> str:
    body = json.dumps({
        "anthropic_version": "bedrock-2023-05-31",
        "max_tokens": 2000,
        "messages": [{"role": "user", "content": prompt}],
    })
    response = client.invoke_model(
        modelId=model, contentType="application/json",
        accept="application/json", body=body,
    )
    result = json.loads(response["body"].read())
    usage = result.get("usage", {})
    costs.record("judge", model,
                 input_tokens=usage.get("input_tokens", len(prompt) // 4),
                 output_tokens=usage.get("output_tokens", len(result["content"][0]["text"]) // 4))
    return result["content"][0]["text"]


def _get_openai_client():
    from openai import OpenAI
    return OpenAI()


def _embed_openai(client, text: str, model: str) -> list[float]:
    response = client.embeddings.create(input=text[:8000], model=model)
    input_tokens = response.usage.total_tokens if response.usage else len(text) // 4
    costs.record("embed", model, input_tokens=input_tokens)
    return response.data[0].embedding


def _judge_openai(client, prompt: str, model: str) -> str:
    response = client.chat.completions.create(
        model=model,
        messages=[{"role": "user", "content": prompt}],
        max_tokens=2000,
    )
    usage = response.usage
    costs.record("judge", model,
                 input_tokens=usage.prompt_tokens if usage else len(prompt) // 4,
                 output_tokens=usage.completion_tokens if usage else 500)
    return response.choices[0].message.content


def get_provider(name: str):
    """Return (client, embed_fn, judge_fn, embed_model, judge_model)."""
    if name == "bedrock":
        return (
            _get_bedrock_client(),
            _embed_bedrock,
            _judge_bedrock,
            os.environ.get("EMBED_MODEL") or "amazon.titan-embed-text-v2:0",
            os.environ.get("JUDGE_MODEL") or "anthropic.claude-3-haiku-20240307-v1:0",
        )
    elif name == "openai":
        return (
            _get_openai_client(),
            _embed_openai,
            _judge_openai,
            os.environ.get("EMBED_MODEL") or "text-embedding-3-small",
            os.environ.get("JUDGE_MODEL") or "gpt-4o-mini",
        )
    else:
        print(f"Unknown provider: {name}. Use 'bedrock' or 'openai'.", file=sys.stderr)
        sys.exit(1)


# ---------------------------------------------------------------------------
# Core logic
# ---------------------------------------------------------------------------

def get_db():
    conn = psycopg2.connect(DB_CONN)
    conn.autocommit = True
    return conn


def seed_controls(client, embed_fn, embed_model):
    conn = get_db()
    cur = conn.cursor()

    cur.execute("CREATE EXTENSION IF NOT EXISTS vector;")
    cur.execute("""
        CREATE TABLE IF NOT EXISTS nist_controls (
            control_id TEXT PRIMARY KEY,
            description TEXT NOT NULL,
            embedding vector(%s) NOT NULL
        );
    """ % EMBED_DIMS)

    cur.execute("SELECT count(*) FROM nist_controls;")
    existing = cur.fetchone()[0]
    if existing > 0:
        print(f"Already seeded ({existing} controls). Use --reseed to replace.")
        return

    print(f"Embedding {len(CONTROLS)} controls...")
    for i, (control_id, description) in enumerate(CONTROLS.items()):
        text = f"{control_id}: {description}"
        embedding = embed_fn(client, text, embed_model)
        cur.execute(
            "INSERT INTO nist_controls (control_id, description, embedding) VALUES (%s, %s, %s::vector) ON CONFLICT (control_id) DO UPDATE SET description = EXCLUDED.description, embedding = EXCLUDED.embedding",
            (control_id, description, str(embedding)),
        )
        if (i + 1) % 10 == 0:
            print(f"  {i + 1}/{len(CONTROLS)}")

    print(f"Seeded {len(CONTROLS)} controls.")
    cur.close()
    conn.close()


def reseed_controls(client, embed_fn, embed_model):
    conn = get_db()
    cur = conn.cursor()
    cur.execute("DELETE FROM nist_controls;")
    cur.close()
    conn.close()
    seed_controls(client, embed_fn, embed_model)


def check_status():
    conn = get_db()
    cur = conn.cursor()
    try:
        cur.execute("SELECT count(*) FROM nist_controls;")
        count = cur.fetchone()[0]
        print(f"Controls seeded: {count}")
    except psycopg2.errors.UndefinedTable:
        print("Not seeded yet. Run: commit-to-control --seed")
    cur.close()
    conn.close()


def get_commit_diff(sha: str) -> str:
    result = subprocess.run(
        ["git", "show", "--stat", "--patch", sha],
        capture_output=True, text=True,
        cwd=os.environ.get("GIT_DIR", "."),
    )
    if result.returncode != 0:
        print(f"git show failed: {result.stderr}", file=sys.stderr)
        sys.exit(1)
    return result.stdout


def map_commit(sha, client, embed_fn, judge_fn, embed_model, judge_model, top_k=TOP_K):
    print(f"Commit: {sha}")
    diff = get_commit_diff(sha)

    if len(diff) > 7000:
        diff_for_embed = diff[:7000]
        print(f"  (diff truncated from {len(diff)} to 7000 chars for embedding)")
    else:
        diff_for_embed = diff

    print(f"Embedding commit diff ({len(diff_for_embed)} chars)...")
    embedding = embed_fn(client, diff_for_embed, embed_model)

    conn = get_db()
    cur = conn.cursor()
    cur.execute(
        """
        SELECT control_id, description,
               1 - (embedding <=> %s::vector) AS similarity
        FROM nist_controls
        ORDER BY embedding <=> %s::vector
        LIMIT %s;
        """,
        (str(embedding), str(embedding), top_k),
    )
    results = cur.fetchall()
    cur.close()
    conn.close()

    lines = diff.split("\n")
    subject = lines[4] if len(lines) > 4 else "(no subject)"
    files_changed = [l for l in lines if l.startswith(" ") and "|" in l]
    print(f"  Subject: {subject.strip()}")
    print(f"  Files: {len(files_changed)}")
    print()

    print("Judging relevance with LLM...")
    candidates = "\n".join(f"- {cid}: {desc}" for cid, desc, _ in results)
    diff_excerpt = diff[:4000]

    judge_prompt = f"""You are a CMMC/NIST 800-171 compliance analyst. A developer made the following commit. I retrieved candidate controls via vector similarity search. Your job: determine which controls this commit ACTUALLY provides evidence for.

COMMIT DIFF (excerpt):
{diff_excerpt}

CANDIDATE CONTROLS:
{candidates}

For each candidate, respond with EXACTLY one of:
- RELEVANT: [control_id] — [one sentence explaining how the commit satisfies this control]
- REJECT: [control_id] — [one sentence explaining why it's a false positive]

Be strict. Only mark RELEVANT if the commit genuinely provides evidence for the control. Infrastructure vocabulary overlap is not enough — the commit must actually implement or demonstrate the control's requirement."""

    judge_text = judge_fn(client, judge_prompt, judge_model)

    print()
    print("NIST 800-171 Control Mapping:")
    print("=" * 72)
    for line in judge_text.strip().split("\n"):
        line = line.strip()
        if not line:
            continue
        if line.startswith("RELEVANT:"):
            print(f"  ✓ {line[9:].strip()}")
        elif line.startswith("REJECT:"):
            print(f"  ✗ {line[7:].strip()}")
        else:
            print(f"  {line}")
    print()

    costs.print_summary()


def main():
    parser = argparse.ArgumentParser(description="Map git commits to NIST 800-171 controls")
    parser.add_argument("commit", nargs="?", default="HEAD", help="Commit SHA (default: HEAD)")
    parser.add_argument("--seed", action="store_true", help="Seed control embeddings into pgvector")
    parser.add_argument("--reseed", action="store_true", help="Re-seed control embeddings (replace existing)")
    parser.add_argument("--status", action="store_true", help="Check if controls are seeded")
    parser.add_argument("--top", type=int, default=TOP_K, help=f"Number of matches (default: {TOP_K})")
    parser.add_argument("--provider", default=PROVIDER, choices=["bedrock", "openai"],
                        help="AI provider (default: openai). For Ollama/vLLM, use openai with OPENAI_BASE_URL.")
    args = parser.parse_args()

    if args.status:
        check_status()
        return

    client, embed_fn, judge_fn, embed_model, judge_model = get_provider(args.provider)

    if args.seed:
        seed_controls(client, embed_fn, embed_model)
    elif args.reseed:
        reseed_controls(client, embed_fn, embed_model)
    else:
        map_commit(args.commit, client, embed_fn, judge_fn, embed_model, judge_model, top_k=args.top)


if __name__ == "__main__":
    main()
